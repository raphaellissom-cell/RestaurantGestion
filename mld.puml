@startuml
!define table(x) entity x ## [b]
!define primary_key(x) <b><color:#B03060><u>x</u></color></b>
!define foreign_key(x) <color:#0066CC><i>x</i></color>
!define not_null(x) <color:#888888>x</color>

hide circle
hide stereotypes
skinparam linetype ortho
skinparam backgroundColor #FEFEFE
skinparam entity {
    BackgroundColor #F8F9FA
    BorderColor #444444
    FontSize 13
    FontName Segoe UI
}

table("tables_restaurant") {
  primary_key(id) INT PK
  --
  numero_table INT NOT NULL
  capacite INT NOT NULL
  statut VARCHAR(255) NOT NULL
  localisation VARCHAR(255) NULL
}

table("produits") {
  primary_key(id_produit) INT PK
  --
  nom VARCHAR(255) NOT NULL
  prix FLOAT NOT NULL
  categorie VARCHAR(255) NOT NULL
  description TEXT NULL
  image_path VARCHAR(255) NULL
  disponible BOOLEAN NULL
  created_at TIMESTAMP NULL
}

table("stocks") {
  primary_key(id_stock) INT PK
  --
  nom_ingredient VARCHAR(255) NOT NULL
  quantite FLOAT NOT NULL
  seuil_alerte FLOAT NOT NULL
  unite VARCHAR(255) NULL
  last_updated TIMESTAMP NULL
}

table("produit_ingredients") {
  primary_key(id) INT PK
  --
  foreign_key(id_produit) INT FK NOT NULL
  foreign_key(id_stock) INT FK NOT NULL
  quantite FLOAT NOT NULL
}

table("commandes") {
  primary_key(id_commande) INT PK
  --
  foreign_key(id_table) INT FK NULL
  date_commande TIMESTAMP NOT NULL
  total FLOAT NOT NULL
  statut VARCHAR(255) NOT NULL
  remise FLOAT NULL
  notes VARCHAR(255) NULL
  serveur VARCHAR(255) NULL
}

table("lignes_commande") {
  primary_key(id_ligne) INT PK
  --
  foreign_key(id_commande) INT FK NOT NULL
  foreign_key(id_produit) INT FK NULL
  quantite INT NOT NULL
  prix_unitaire FLOAT NOT NULL
}

table("paiements") {
  primary_key(id_paiement) INT PK
  --
  foreign_key(id_commande) INT FK NOT NULL
  mode_paiement VARCHAR(255) NOT NULL
  montant_recu FLOAT NOT NULL
  date_paiement TIMESTAMP NOT NULL
}

table("factures") {
  primary_key(id_facture) INT PK
  --
  foreign_key(id_commande) INT FK NOT NULL
  total FLOAT NOT NULL
  date_generation TIMESTAMP NOT NULL
  numero_facture VARCHAR(255) NULL
  mode_paiement VARCHAR(255) NULL
  chemin_pdf VARCHAR(255) NULL
}

' === Relationships ===

tables_restaurant ||..o{ commandes : "1,N"
commandes ||..|{ lignes_commande : "1,N"
commandes ||..|| paiements : "1,1"
commandes ||..|| factures : "1,1"
produits ||..o{ lignes_commande : "1,N"
produits ||..|{ produit_ingredients : "1,N"
stocks ||..|{ produit_ingredients : "1,N"

@enduml
